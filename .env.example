# =============================================================================
# Sentinel Risk Guardian - Environment Configuration (EXAMPLE)
# =============================================================================
# Copy this file to `.env` and fill in real values locally.
# NEVER commit a populated `.env` file. Secrets MUST live in environment
# variables only, never in source code or public evidence bundles. (Req 16.3)
#
# Sentinel runs on Sui Testnet and Walrus Testnet ONLY for the hackathon demo.
# Mainnet is disabled. (Req 1)
# =============================================================================

# -----------------------------------------------------------------------------
# Sui Testnet network (Req 1.1, 16.3)
# -----------------------------------------------------------------------------
# Sui Testnet JSON-RPC endpoint. Backend refuses to start if the chain
# identifier does not match Sui Testnet. (Req 1.3, 1.4)
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
# Expected Sui Testnet chain identifier used by the Network Guard for verification.
SUI_TESTNET_CHAIN_ID=4c78adac
# Published Move package IDs on Sui Testnet (filled in after deploy - task 3.12).
SENTINEL_POLICY_PACKAGE_ID=
SENTINEL_DEMO_MARKET_PACKAGE_ID=
SENTINEL_ADAPTERS_PACKAGE_ID=

# -----------------------------------------------------------------------------
# Walrus Testnet evidence storage (Req 1.2, 10, 16.3)
# -----------------------------------------------------------------------------
# Walrus Testnet publisher/aggregator endpoints for evidence bundle storage.
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# -----------------------------------------------------------------------------
# Agent signer (Req 16.1, 16.2, 16.3)
# -----------------------------------------------------------------------------
# Server-side agent signer private key (Sui keypair, base64 or bech32).
# Held by the BACKEND ONLY and never exposed to the frontend. Least-privilege:
# authority is bounded on-chain by the GuardianCap. Leave blank in version control.
AGENT_SIGNER_KEY=

# -----------------------------------------------------------------------------
# Datastores (Req 16.3)
# -----------------------------------------------------------------------------
# PostgreSQL: relational config + time-series risk snapshots.
# Host port 5434 matches docker-compose.yml (avoids clashing with a local 5432).
DATABASE_URL=postgresql://sentinel:sentinel@localhost:5434/sentinel
# Redis: hot snapshot cache + background job queue.
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Backend service
# -----------------------------------------------------------------------------
PORT=4000
NODE_ENV=development
# Configurable API rate limit (requests per window). (Req 15.5)
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# AI Explanation Service (Req 6.5, 6.13) - explanation only, no action authority
# DeepSeek is OpenAI-compatible. Current V4 model IDs: deepseek-v4-flash / deepseek-v4-pro.
# -----------------------------------------------------------------------------
# API key for the LLM provider used to generate plain-language explanations.
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash
LLM_BASE_URL=https://api.deepseek.com

# -----------------------------------------------------------------------------
# Frontend (public, non-secret values only - exposed to the browser)
# -----------------------------------------------------------------------------
PUBLIC_SUI_NETWORK=testnet
PUBLIC_BACKEND_URL=http://localhost:4000
PUBLIC_WS_URL=ws://localhost:4000
# Published Move package IDs exposed to the browser (filled in after deploy -
# task 3.12, written by scripts/deploy_testnet.sh into frontend/.env).
PUBLIC_SENTINEL_POLICY_PACKAGE_ID=
PUBLIC_SENTINEL_DEMO_MARKET_PACKAGE_ID=
PUBLIC_SENTINEL_ADAPTERS_PACKAGE_ID=
