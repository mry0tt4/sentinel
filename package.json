{
  "name": "sentinel-risk-guardian",
  "version": "0.1.0",
  "private": true,
  "description": "Sentinel: AI-assisted risk-control loop for Sui DeFi markets (Sui Testnet + Walrus Testnet).",
  "license": "MIT",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx,.astro",
    "lint:fix": "eslint . --ext .ts,.tsx,.astro --fix",
    "format": "prettier --write \"**/*.{ts,tsx,astro,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,astro,json,md}\"",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "verify": "node scripts/verify-submission.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "astro-eslint-parser": "^1.4.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-astro": "^1.7.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  }
}
