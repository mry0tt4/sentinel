---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { AppShell } from '../../components/AppShell';

export const prerender = false;

// Incident Replay page (`/incidents/:id`). The id comes from the route param
// and is handed to the shared AppShell island (one wallet provider). (Req 13)
const { id } = Astro.params;
const incidentId = id ?? '';
---

<BaseLayout title={`Incident ${incidentId} — Sentinel`}>
  <AppShell client:only="react" page="incident" incidentId={incidentId} currentPath="/incidents" />

  <style>
    header h1 {
      margin: 0.75rem 0 0.5rem;
      font-size: 2rem;
    }
    footer {
      margin-top: 2.5rem;
      color: var(--muted);
      font-size: 0.85rem;
    }

    /* ---- Incident replay (scoped to this page) ---- */
    .incident {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }
    .incident__title-row {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-wrap: wrap;
    }
    .incident__title {
      margin: 0;
      font-size: 1.4rem;
    }
    .incident__meta {
      display: flex;
      gap: 1.25rem;
      flex-wrap: wrap;
      color: var(--muted);
      font-size: 0.85rem;
      margin: 0.25rem 0 0;
    }
    .incident__summary {
      margin: 0.25rem 0 0;
    }
    .incident__heading {
      margin: 0 0 0.5rem;
      font-size: 1rem;
    }
    .incident__steps {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      border-left: 2px solid var(--border, #2a2a35);
      padding-left: 1rem;
    }
    .incident__step {
      position: relative;
    }
    .incident__empty,
    .incident__loading,
    .incident__error {
      color: var(--muted);
      font-size: 0.9rem;
    }
    .incident__error {
      color: #f87171;
    }

    .incident-sim-marker {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.1rem 0.55rem;
      border-radius: 999px;
      background: #7c3aed22;
      color: #c4b5fd;
      border: 1px solid #7c3aed55;
      font-size: 0.75rem;
      font-weight: 500;
    }
    .incident-sim-marker__scenario {
      font-weight: 400;
      opacity: 0.85;
    }

    .incident-snapshot,
    .incident-action {
      background: var(--card, #16161d);
      border: 1px solid var(--border, #2a2a35);
      border-radius: 0.6rem;
      padding: 0.85rem 1rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .incident-action {
      border-left: 3px solid #f59e0b;
    }
    .incident-snapshot__head,
    .incident-action__head {
      display: flex;
      align-items: baseline;
      gap: 0.75rem;
      flex-wrap: wrap;
    }
    .incident-snapshot__band,
    .incident-action__type {
      font-weight: 500;
    }
    .incident-snapshot__time,
    .incident-action__actor,
    .incident-action__score {
      color: var(--muted);
      font-size: 0.8rem;
    }
    .incident-snapshot__delta--up {
      color: #f87171;
    }
    .incident-snapshot__delta--down {
      color: #4ade80;
    }
    .incident-snapshot__classes {
      list-style: none;
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin: 0;
      padding: 0;
    }
    .incident-snapshot__classes li {
      font-size: 0.7rem;
      padding: 0.05rem 0.4rem;
      border-radius: 0.3rem;
      background: #ffffff10;
    }
    .incident-snapshot__explanation--none,
    .incident-action__blob--none {
      color: var(--muted);
      font-style: italic;
    }

    .incident-action__markers {
      display: flex;
      gap: 0.4rem;
      flex-wrap: wrap;
    }
    .incident-action__marker {
      font-size: 0.7rem;
      font-weight: 500;
      padding: 0.1rem 0.45rem;
      border-radius: 0.3rem;
    }
    .incident-action__marker--override {
      background: #2563eb22;
      color: #93c5fd;
    }
    .incident-action__marker--revocation,
    .incident-action__marker--reversed {
      background: #dc262622;
      color: #fca5a5;
    }
    .incident-action__marker--reversal {
      background: #ca8a0422;
      color: #fcd34d;
    }
    .incident-action__reason {
      margin: 0;
      font-size: 0.85rem;
    }
    .incident-params {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin: 0;
    }
    .incident-params__pair {
      display: flex;
      flex-direction: column;
    }
    .incident-params__pair dt {
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--muted);
    }
    .incident-params__pair dd {
      margin: 0;
      font-variant-numeric: tabular-nums;
    }
    .incident-action__evidence {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }
    .incident-action__evidence-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .incident-action__label {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--muted);
      min-width: 5rem;
    }
    .incident-action__blob,
    .tx-digest {
      font-size: 0.8rem;
      word-break: break-all;
    }
    .tx-digest--blocked {
      color: #f87171;
    }
  </style>
</BaseLayout>
