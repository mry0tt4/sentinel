---
import BaseLayout from '../layouts/BaseLayout.astro';
import { AppShell } from '../components/AppShell';
---

<BaseLayout title="Override console — Sentinel">
  <AppShell client:only="react" page="admin" currentPath="/admin" />

  <style>
    /* ---- Override console (Req 11) ---- */
    :global(.override-console) {
      margin-top: 1rem;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
    :global(.override-console__title) {
      margin: 0;
      font-size: 1.4rem;
    }
    :global(.override-console__sub) {
      margin: 0.25rem 0 0;
      color: var(--muted);
      font-size: 0.9rem;
    }
    :global(.override-console__list) {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
    :global(.override-console__warning),
    :global(.override-console__error),
    :global(.override-error) {
      color: var(--warn);
      font-size: 0.85rem;
      margin: 0;
    }
    :global(.override-console__hint),
    :global(.override-console__loading),
    :global(.override-console__empty),
    :global(.override-hint) {
      color: var(--muted);
      font-size: 0.85rem;
      margin: 0;
    }

    :global(.override-panel) {
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: var(--surface);
      box-shadow: var(--shadow);
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    :global(.override-panel__head) {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 0.75rem;
    }
    :global(.override-panel__name) {
      margin: 0;
      font-size: 1.15rem;
    }
    :global(.override-panel__status) {
      color: var(--muted);
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    :global(.override-panel__subhead) {
      margin: 0 0 0.5rem;
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--muted);
    }
    :global(.override-badge--paused) {
      background: rgba(248, 113, 113, 0.15);
      color: var(--warn);
      border-radius: 999px;
      padding: 0.15rem 0.6rem;
      font-size: 0.75rem;
    }

    :global(.override-grid) {
      display: grid;
      gap: 0.3rem;
      margin: 0;
    }
    :global(.override-grid__row) {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      padding: 0.25rem 0;
      border-bottom: 1px solid var(--border);
    }
    :global(.override-grid__row dt) {
      color: var(--muted);
      font-size: 0.85rem;
    }
    :global(.override-grid__row dd) {
      margin: 0;
      font-size: 0.85rem;
      text-align: right;
      word-break: break-word;
    }
    :global(.override-grid__mono) {
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    }

    :global(.override-controls) {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    :global(.override-control) {
      border: 1px solid var(--border-strong);
      background: var(--surface);
      color: var(--fg);
      border-radius: 10px;
      padding: 0.4rem 0.85rem;
      font-size: 0.85rem;
      font-weight: 500;
      cursor: pointer;
      transition: border-color 0.15s ease, background 0.15s ease;
    }
    :global(.override-control:hover:not(:disabled)) {
      background: var(--surface-2);
    }
    :global(.override-control--active) {
      border-color: var(--accent);
      background: rgba(79, 70, 229, 0.08);
      color: var(--accent);
    }
    :global(.override-control:disabled) {
      opacity: 0.45;
      cursor: not-allowed;
    }

    :global(.override-stage) {
      border-top: 1px solid var(--border);
      padding-top: 0.85rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    :global(.override-preview) {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.85rem;
    }
    :global(.override-preview th),
    :global(.override-preview td) {
      text-align: left;
      padding: 0.3rem 0.5rem;
      border-bottom: 1px solid var(--border);
    }
    :global(.override-thresholds) {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem;
    }
    :global(.override-thresholds label),
    :global(.override-reason) {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      font-size: 0.8rem;
      color: var(--muted);
    }
    :global(.override-reason textarea) {
      min-height: 3.5rem;
      resize: vertical;
      font: inherit;
      padding: 0.5rem;
      border-radius: 10px;
      border: 1px solid var(--border-strong);
      background: var(--input-bg);
      color: var(--fg);
    }
    :global(.override-submit) {
      align-self: flex-start;
      border: 1px solid var(--purple-edge);
      border-radius: 10px;
      padding: 0.6rem 1.2rem;
      font-size: 0.9rem;
      font-weight: 500;
      cursor: pointer;
      background: var(--purple);
      color: #fff;
      text-shadow: 0 1px 1px rgba(40, 28, 110, 0.45);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.45),
        inset 0 2px 3px rgba(255, 255, 255, 0.18),
        inset 0 -6px 12px rgba(40, 28, 110, 0.5),
        inset 0 -1px 0 rgba(40, 28, 110, 0.6);
      transition: background 0.15s ease, transform 0.12s ease;
    }
    :global(.override-submit:hover:not(:disabled)) {
      background: var(--purple-hi);
    }
    :global(.override-submit:disabled) {
      opacity: 0.45;
      cursor: not-allowed;
      box-shadow: none;
    }
    :global(.override-result__digest) {
      display: flex;
      gap: 0.5rem;
      align-items: center;
      font-size: 0.85rem;
    }
    :global(.tx-digest) {
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: 0.8rem;
      word-break: break-all;
    }
    :global(.tx-digest--blocked) {
      color: var(--warn);
    }
    @media (max-width: 640px) {
      :global(.override-thresholds) {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
