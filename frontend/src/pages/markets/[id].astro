---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { AppShell } from '../../components/AppShell';

export const prerender = false;

const { id } = Astro.params;
---

<BaseLayout title="Market detail — Sentinel">
  <AppShell client:only="react" page="market" marketId={id} currentPath="/markets" />

  <style>
    header h1 {
      margin: 0.75rem 0 0.5rem;
      font-size: 2rem;
    }
    footer {
      margin-top: 2.5rem;
      color: var(--muted);
      font-size: 0.85rem;
    }

    /* ---- Single-market detail page (Req 3.3–3.6) ---- */
    :global(.market-detail) {
      margin-top: 2rem;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }
    :global(.market-detail__title-row) {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 0.75rem;
      flex-wrap: wrap;
    }
    :global(.market-detail__header) {
      flex: 1;
    }
    :global(.market-detail__name) {
      margin: 0;
      font-size: 1.6rem;
    }
    :global(.market-detail__subtitle) {
      margin: 0.25rem 0 0;
      color: var(--muted);
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    :global(.market-detail__risk-row) {
      display: flex;
      gap: 1.5rem;
      flex-wrap: wrap;
      align-items: center;
    }
    :global(.market-detail__trend) {
      border: 1px solid rgba(148, 163, 184, 0.2);
      border-radius: 0.75rem;
      padding: 1rem 1.25rem;
    }
    :global(.market-detail__cards) {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
    }
    @media (max-width: 640px) {
      :global(.market-detail__cards) {
        grid-template-columns: 1fr;
      }
    }
    :global(.market-detail__error) {
      color: var(--warn);
      font-size: 0.85rem;
    }
    :global(.market-detail__loading) {
      color: var(--muted);
    }
    :global(.market-card) {
      border: 1px solid rgba(148, 163, 184, 0.2);
      border-radius: 0.75rem;
      padding: 1.25rem;
    }
    :global(.market-card__heading) {
      margin: 0 0 0.75rem;
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--muted);
    }
    :global(.market-card__grid) {
      display: grid;
      gap: 0.4rem;
      margin: 0;
    }
    :global(.market-card__grid + .market-card__grid) {
      margin-top: 0.75rem;
      padding-top: 0.75rem;
      border-top: 1px solid rgba(148, 163, 184, 0.15);
    }
    :global(.market-card__row) {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      padding: 0.3rem 0;
      border-bottom: 1px solid rgba(148, 163, 184, 0.12);
    }
    :global(.market-card__label) {
      color: var(--muted);
      font-size: 0.85rem;
    }
    :global(.market-card__value) {
      margin: 0;
      font-size: 0.85rem;
      text-align: right;
      word-break: break-word;
    }
    :global(.market-card__value--mono) {
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    }
    :global(.market-card__empty) {
      color: var(--muted);
      font-size: 0.9rem;
      margin: 0;
    }
    :global(.tx-digest) {
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: 0.8rem;
      word-break: break-all;
    }
    :global(.tx-digest--blocked) {
      color: var(--warn);
    }
  </style>
</BaseLayout>
