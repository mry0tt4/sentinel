      .mk-dash__titlewrap { display: inline-flex; align-items: center; gap: 0.6rem; }
      .mk-dash__title { font-size: 1.05rem; font-weight: 500; letter-spacing: -0.01em; }
      .mk-seg {
        display: inline-flex;
        background: var(--surface-2);
        border: 1px solid var(--border);
        border-radius: 9px;
        padding: 0.15rem;
        gap: 0.1rem;
      }
      .mk-seg__item {
        font-size: 0.68rem;
        font-weight: 500;
        color: var(--muted);
        padding: 0.2rem 0.55rem;
        border-radius: 7px;
      }
      .mk-seg__item--on { background: var(--surface); color: var(--fg); box-shadow: var(--shadow-sm); }

      /* KPI tile deltas */
      .mk-tile__d { font-size: 0.62rem; color: var(--muted); font-weight: 500; }
      .mk-tile__d--ok { color: var(--ok); }

      /* sidebar signal rows */
      .mk-side-kv {
        display: flex;
        justify-content: space-between;
        gap: 0.5rem;
        font-size: 0.68rem;
        color: var(--muted);
        padding: 0.18rem 0.1rem;
      }
      .mk-side-kv b { color: var(--fg); font-weight: 500; font-variant-numeric: tabular-nums; }

      /* lower split: recent actions + policy bounds */
      .mk-dash__lower {
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        gap: 1rem;
      }
      .mk-mini {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 11px;
        padding: 0.8rem 0.9rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }
      .mk-mini__h {
        font-size: 0.64rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--muted);
      }
      .mk-act {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.72rem;
        color: var(--fg-soft);
      }
      .mk-act__dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--muted);
        flex: 0 0 auto;
      }
      .mk-act__dot--ok { background: var(--ok); }
      .mk-act__dot--warn { background: var(--warn); }
      .mk-act__name { font-family: var(--mono); font-size: 0.68rem; color: var(--fg); }
      .mk-act__t { margin-left: auto; font-size: 0.64rem; color: var(--muted); }
      @media (max-width: 720px) {
        .mk-dash__lower { grid-template-columns: 1fr; }
      }
      .mk-panel__hd {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        margin-bottom: 0.85rem;
      }
      .mk-legend {
        display: flex;
        gap: 0.85rem;
        font-size: 0.68rem;
        color: var(--muted);
      }
      .mk-legend span { display: inline-flex; align-items: center; gap: 0.3rem; }
      .mk-legend i { width: 9px; height: 9px; border-radius: 3px; display: inline-block; }
      /* Bar chart */
      .mk-bars {
        display: flex;
        align-items: flex-end;
        gap: 0.55rem;
        height: 320px;
        flex: 1;
        padding-top: 1.5rem;
      }
      .mk-bars__col { flex: 1; height: 100%; display: flex; align-items: flex-end; }
      .mk-bars__bar {
        position: relative;
        width: 100%;
        border-radius: 6px 6px 3px 3px;
        opacity: 0.92;
      }
      .mk-bars__tag {
        position: absolute;
        top: -1.35rem;
        left: 50%;
        transform: translateX(-50%);
        white-space: nowrap;
        font-size: 0.6rem;
        color: var(--muted);
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 0.05rem 0.35rem;
      }
      @media (max-width: 720px) {
        .mk-dash__grid { grid-template-columns: 1fr; }
        .mk-dash__side { display: none; }
        .mk-hero-dash .mk-dash__impact { grid-template-columns: 1fr 1fr; }
        .mk-ai__chip { display: none; }
        .mk-ai__chip--hide { display: none; }
      }

      /* legacy v2 mockwrap shadow override removed */
      .__mk_noop { display: none; }
      .mk-browser {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04), 0 44px 90px -46px rgba(15, 23, 42, 0.34);
        overflow: hidden;
      }
      .mk-browser__bar {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.6rem 0.85rem;
        border-bottom: 1px solid var(--border);
        background: var(--surface-2);
      }
      .mk-browser__dot {
        width: 9px;
        height: 9px;
        border-radius: 50%;
        background: var(--border-strong);
      }
      .mk-browser__url {
        margin-left: 0.6rem;
        font-size: 0.72rem;
        color: var(--muted);
        font-family: var(--mono);
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 7px;
        padding: 0.12rem 0.6rem;
      }
      .mk-browser__live {
        margin-left: auto;
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.7rem;
        color: var(--ok);
      }
      .mk-dash {
        display: grid;
        grid-template-columns: 180px 1fr;
        gap: 1rem;
        padding: 1rem;
        background:
          radial-gradient(30rem 16rem at 70% -10%, rgba(99, 102, 241, 0.06), transparent 70%),
          var(--bg);
      }
      @media (max-width: 620px) {
        .mk-dash { grid-template-columns: 1fr; }
        .mk-dash__side { display: none; }
        .mk-dash__charts { grid-template-columns: 1fr 1fr; }
      }
      .mk-dash__side {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 0.75rem;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
      }
      .mk-dash__sidehead {
        font-size: 0.62rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--muted);
        margin-bottom: 0.2rem;
      }
      .mk-dash__market {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.4rem;
        padding: 0.45rem 0.55rem;
        border-radius: 9px;
        border: 1px solid var(--border);
        font-size: 0.76rem;
        color: var(--fg-soft);
      }
      .mk-dash__market--sel {
        border-color: var(--accent);
        background: rgba(79, 70, 229, 0.06);
        color: var(--fg);
      }
      .mk-dash__main {
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
        min-width: 0;
      }
      .mk-dash__impact {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.6rem;
      }
      .mk-tile {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 11px;
        padding: 0.6rem 0.7rem;
        display: flex;
        flex-direction: column;
        gap: 0.1rem;
      }
      .mk-tile__k {
        font-size: 0.62rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--muted);
      }
      .mk-tile__v {
        font-size: 1.15rem;
        font-weight: 500;
        font-variant-numeric: tabular-nums;
      }
      .mk-dash__row {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1rem 1.1rem;
      }
      .mk-dash__charts {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.6rem;
      }
      .mk-panel {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 11px;
        padding: 0.6rem 0.7rem;
      }
      .mk-panel__h {
        display: block;
        font-size: 0.64rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--muted);
        margin-bottom: 0.25rem;
      }
      .mk-gauge {
        position: relative;
        border-radius: 50%;
        flex: 0 0 auto;
        display: grid;
        place-items: center;
      }
      .mk-gauge__hole {
        position: absolute;
        inset: 10px;
        border-radius: 50%;
        background: var(--surface);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
      }
      .mk-gauge__score {
        font-size: 1.4rem;
        font-weight: 500;
        line-height: 1;
      }
      .mk-gauge__band {
        font-size: 0.54rem;
        text-transform: uppercase;
        letter-spacing: 0.03em;
      }
      .mk-kv {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        min-width: 0;
      }
      .mk-kv__row {
        display: flex;
        justify-content: space-between;
        gap: 0.75rem;
        font-size: 0.78rem;
        color: var(--muted);
        border-bottom: 1px solid var(--border);
        padding-bottom: 0.28rem;
      }
      .mk-kv__row b {
        color: var(--fg);
        font-weight: 500;
        font-variant-numeric: tabular-nums;
      }
      .mk-kv--sm .mk-kv__row {
        font-size: 0.68rem;
        padding-bottom: 0.18rem;
      }
      .mk-bad { color: var(--warn) !important; }
      .mk-spark { width: 100%; height: 44px; display: block; }
      .mk-pill {
        font-size: 0.6rem;
        font-weight: 500;
        padding: 0.08rem 0.4rem;
        border-radius: 999px;
        background: var(--surface-2);
        color: var(--muted);
        border: 1px solid var(--border);
        white-space: nowrap;
      }
      .mk-pill--ok { background: rgba(5, 150, 105, 0.12); color: var(--ok); border-color: rgba(5, 150, 105, 0.2); }
      .mk-pill--warn { background: rgba(217, 119, 6, 0.14); color: var(--warn); border-color: rgba(217, 119, 6, 0.22); }
      .mk-pill--indigo { background: rgba(79, 70, 229, 0.1); color: var(--accent); border-color: rgba(79, 70, 229, 0.2); }
      .mk-tag {
        font-size: 0.64rem;
        font-weight: 500;
        padding: 0.12rem 0.5rem;
        border-radius: 999px;
        background: var(--surface-2);
        color: var(--muted);
        border: 1px solid var(--border);
      }
      .mk-tag--ok { background: rgba(5, 150, 105, 0.12); color: var(--ok); border-color: rgba(5, 150, 105, 0.2); }
      .mk-tag--indigo { background: rgba(79, 70, 229, 0.1); color: var(--accent); border-color: rgba(79, 70, 229, 0.2); }
      .mk-tag--muted { font-size: 0.58rem; }

      /* ===== Bento (v2) — tinted cards with floating UI mockups ===== */
      .lp-bento {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 1.25rem;
      }
      .bento {
        position: relative;
        min-height: 440px;
        display: flex;
        flex-direction: column;
        border-radius: 22px;
        border: 1px solid var(--border);
        padding: 2rem 2.1rem 0;
        overflow: hidden;
        background: var(--surface-2);
        transition: border-color 0.18s ease, box-shadow 0.18s ease;
      }
      /* Cards themselves are flat (no hover effect) — only the graphic (.mk-card)
         lifts on hover, handled below. */
      /* Row 1 = 60 / 40, Row 2 = 40 / 60 (5-col grid). */
      .bento:nth-child(1) { grid-column: 1 / 4; }
      .bento:nth-child(2) { grid-column: 4 / 6; }
      .bento:nth-child(3) { grid-column: 1 / 3; }
      .bento:nth-child(4) { grid-column: 3 / 6; }
      @media (max-width: 860px) {
        .lp-bento { grid-template-columns: 1fr; }
        .bento { grid-column: auto !important; min-height: 360px; }
      }
      .bento--slate { background: linear-gradient(180deg, #f4f6f9, #eef1f6); }
      .bento--indigo { background: linear-gradient(180deg, #f2f1fe, #ece9fd); border-color: rgba(99,102,241,0.18); }
      .bento--mint { background: linear-gradient(180deg, #eefaf4, #e3f5ec); border-color: rgba(5,150,105,0.18); }
      .bento--cyan { background: linear-gradient(180deg, #eef9fc, #e0f2f7); border-color: rgba(8,145,178,0.18); }
      .bento__head { position: relative; z-index: 2; max-width: 30rem; }
      .bento__head h3 { margin: 0; font-size: 1.45rem; letter-spacing: -0.015em; }
      .bento__head p { margin: 0.4rem 0 0; color: var(--muted); font-size: 0.95rem; line-height: 1.55; }
      .bento__art {
        position: relative;
        z-index: 1;
        flex: 1;
        display: flex;
        align-items: flex-end;
        justify-content: center;
        padding-top: 1rem;
      }
      .bento__art .mk-card {
        width: min(100%, 27rem);
        margin-bottom: -1.5rem;
        transition: transform 0.24s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.24s ease;
        will-change: transform;
      }
      .bento:hover .mk-card {
        transform: translateY(-14px);
        box-shadow: 0 1px 2px rgba(15,23,42,0.05), 0 38px 64px -34px rgba(15,23,42,0.42);
      }
      /* Wider cards in the 60%-width bento cells */
      .bento:nth-child(1) .mk-card,
      .bento:nth-child(4) .mk-card { width: min(100%, 30rem); }
      @media (max-width: 860px) {
        .bento__art .mk-card,
        .bento:nth-child(1) .mk-card,
        .bento:nth-child(4) .mk-card { width: min(100%, 30rem); }
      }
      .mk-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 13px;
        padding: 0.85rem 0.9rem;
        box-shadow: 0 1px 2px rgba(15,23,42,0.05), 0 26px 50px -30px rgba(15,23,42,0.32);
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
      }
      .mk-card--float { transform: rotate(-1deg); }
      .bento--indigo .mk-card--float,
      .bento--cyan .mk-card--float { transform: rotate(1deg); }
      .mk-card__top { display: flex; align-items: center; gap: 0.9rem; }
      .mk-monitor { gap: 0.85rem; }
      .mk-monitor__top { display: flex; align-items: center; gap: 1rem; }
      .mk-monitor__chart {
        border-top: 1px solid var(--border);
        padding-top: 0.6rem;
      }
      .mk-monitor__chart .mk-spark { height: 56px; }
      .mk-meter--off { opacity: 0.5; }
      .mk-card__hd { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; }
      .mk-bound {
        display: grid;
        grid-template-columns: 4.5rem 1fr auto;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.68rem;
        color: var(--muted);
      }
      .mk-bound b { color: var(--fg); font-weight: 500; font-variant-numeric: tabular-nums; }
      .mk-meter { height: 6px; border-radius: 999px; background: var(--surface-2); border: 1px solid var(--border); overflow: hidden; }
      .mk-meter i { display: block; height: 100%; background: var(--gradient); }
      .mk-why { font-size: 0.8rem; font-weight: 500; display: inline-flex; align-items: center; gap: 0.4rem; }
      .mk-why__text { margin: 0; font-size: 0.74rem; color: var(--fg-soft); line-height: 1.45; }
      .mk-why__text b { color: var(--fg); }
      .mk-rule {
        display: flex;
        justify-content: space-between;
        font-size: 0.68rem;
        color: var(--muted);
        padding: 0.25rem 0.45rem;
        border-radius: 7px;
        background: var(--surface-2);
      }
      .mk-rule b { color: var(--fg-soft); font-family: var(--mono); }
      .mk-rule--fired { background: rgba(217, 119, 6, 0.1); color: var(--warn); }
      .mk-rule--fired b { color: var(--warn); }
      .mk-evi { display: flex; flex-direction: column; gap: 0.45rem; }
      .mk-evi__row { display: flex; align-items: center; gap: 0.5rem; font-size: 0.68rem; color: var(--muted); }
      .mk-evi__row code { font-family: var(--mono); font-size: 0.66rem; color: var(--fg-soft); background: var(--surface-2); border: 1px solid var(--border); border-radius: 6px; padding: 0.05rem 0.35rem; }
      .mk-override { border-top: 1px solid var(--border); padding-top: 0.55rem; }
      .mk-override__h { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); }
      .mk-override__btns { display: flex; gap: 0.35rem; margin-top: 0.4rem; }
      .mk-btn { font-size: 0.66rem; padding: 0.22rem 0.55rem; border-radius: 7px; border: 1px solid var(--border-strong); background: var(--surface); color: var(--fg-soft); }
      .mk-btn--primary { background: var(--purple); color: #fff; border-color: var(--purple-edge); box-shadow: inset 0 1px 0 rgba(255,255,255,0.4), inset 0 -3px 6px rgba(40,28,110,0.5); }

      /* footer rows for the bento mock cards */
      .mk-monitor__feet {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        flex-wrap: wrap;
        border-top: 1px solid var(--border);
        padding-top: 0.6rem;
      }
      .mk-monitor__feet .mk-src { font-size: 0.62rem; padding: 0.18rem 0.45rem; }
      .mk-monitor__feet .mk-src:last-child {
        margin-left: auto;
        background: transparent;
        border-color: transparent;
        color: var(--muted);
      }
      .mk-cap {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        font-size: 0.66rem;
        color: var(--fg-soft);
        font-family: var(--mono);
        background: var(--surface-2);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 0.4rem 0.55rem;
      }
      .mk-cap__dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--ok);
        box-shadow: 0 0 0 3px rgba(5, 150, 105, 0.16);
        flex: 0 0 auto;
      }
      .mk-policy-foot,
      .mk-why__foot {
        border-top: 1px solid var(--border);
        padding-top: 0.55rem;
        font-size: 0.64rem;
        color: var(--muted);
        letter-spacing: 0.01em;
      }

      /* Inner-page action buttons aligned to the landing primary/ghost styles */
      .override-submit,
      .override-controls__submit,
      .scenario-picker__start {
        background: var(--purple);
        color: #fff;
        border: 1px solid var(--purple-edge);
        padding: 0.65rem 1.2rem;
        border-radius: 10px;
        font-family: inherit;
        font-size: 0.92rem;
        font-weight: 500;
        cursor: pointer;
        text-shadow: 0 1px 1px rgba(40, 28, 110, 0.45);
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.45),
          inset 0 2px 3px rgba(255, 255, 255, 0.18),
          inset 0 -6px 12px rgba(40, 28, 110, 0.5),
          inset 0 -1px 0 rgba(40, 28, 110, 0.6);
        transition: background 0.15s ease, transform 0.12s ease, opacity 0.15s ease;
      }
      .override-submit:hover:not(:disabled),
      .override-controls__submit:hover:not(:disabled),
      .scenario-picker__start:hover:not(:disabled) {
        background: var(--purple-hi);
      }
      .override-submit:active:not(:disabled),
      .override-controls__submit:active:not(:disabled),
      .scenario-picker__start:active:not(:disabled) {
        transform: translateY(1px);
      }
      .override-submit:disabled,
      .override-controls__submit:disabled,
      .scenario-picker__start:disabled {
        opacity: 0.45;
        cursor: not-allowed;
        box-shadow: none;
      }
      .scenario-picker__reset {
        background: var(--surface);
        border: 1px solid var(--border-strong);
        color: var(--fg);
        padding: 0.65rem 1.2rem;
        border-radius: 10px;
        font-family: inherit;
        font-size: 0.92rem;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.15s ease;
      }
      .scenario-picker__reset:hover:not(:disabled) {
        background: var(--surface-2);
      }

      /* ----- Info hint (newbie-friendly explanations) ----- */
      .info-hint {
        position: relative;
        display: inline-flex;
        align-items: center;
        margin-left: 0.4rem;
        vertical-align: middle;
        cursor: help;
        outline: none;
      }
      .info-hint__icon {
        display: grid;
        place-items: center;
        width: 15px;
        height: 15px;
        border-radius: 50%;
        border: 1px solid var(--border-strong);
        background: var(--surface);
        color: var(--muted);
        font-size: 0.62rem;
        font-style: normal;
        font-weight: 500;
        line-height: 1;
        font-family: var(--font);
      }
      .info-hint:hover .info-hint__icon,
      .info-hint:focus-visible .info-hint__icon {
        color: var(--accent);
        border-color: var(--accent);
      }
      .info-hint__pop {
        position: absolute;
        bottom: calc(100% + 9px);
        left: 50%;
        transform: translateX(-50%);
        width: max-content;
        max-width: 250px;
        padding: 0.55rem 0.7rem;
        border-radius: 9px;
        background: var(--fg);
        color: #fff;
        font-size: 0.74rem;
        font-weight: 400;
        line-height: 1.45;
        letter-spacing: normal;
        text-transform: none;
        text-align: left;
        white-space: normal;
        box-shadow: 0 8px 24px -8px rgba(15, 23, 42, 0.5);
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.15s ease;
        z-index: 70;
        pointer-events: none;
      }
      .info-hint__pop::after {
        content: '';
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%);
        border: 5px solid transparent;
        border-top-color: var(--fg);
      }
      .info-hint:hover .info-hint__pop,
      .info-hint:focus .info-hint__pop,
      .info-hint:focus-within .info-hint__pop {
        opacity: 1;
        visibility: visible;
      }

      /* ----- Real-event replay panel ----- */
      .replay {
        margin-top: 1.5rem;
        padding: 1.25rem 1.35rem;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: var(--surface);
        box-shadow: var(--shadow-sm);
      }
      .replay__loading {
        color: var(--muted);
