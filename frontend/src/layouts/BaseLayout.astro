---
interface Props {
  title?: string;
}

const { title = 'Sentinel Risk Guardian' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="AI-assisted, bounded autonomous risk control for Sui DeFi markets." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=switzer@400,500,600&display=swap"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />

    <style is:global>
      :root {
        color-scheme: light;
        --bg: #f6f7f9;
        --bg-tint: #eef1f6;
        --surface: #ffffff;
        --surface-2: #f3f5f8;
        --border: #e6e8ee;
        --border-strong: #d3d8e2;
        --fg: #0f172a;
        --fg-soft: #334155;
        --muted: #64748b;
        --ok: #059669;
        --warn: #d97706;
        --danger: #dc2626;
        --accent: #4f46e5;
        --accent-2: #0891b2;
        --purple: #6d5dfc;
        --purple-hi: #8474ff;
        --purple-edge: #4f3fd6;
        --input-bg: #ffffff;
        --radius: 16px;
        --radius-sm: 10px;
        --shadow-sm: 0 1px 2px rgba(15, 23, 42, 0.05), 0 1px 3px rgba(15, 23, 42, 0.04);
        --shadow: 0 1px 2px rgba(15, 23, 42, 0.04), 0 18px 40px -24px rgba(15, 23, 42, 0.22);
        --gradient: linear-gradient(135deg, #8b7bff 0%, #6d5dfc 55%, #4f3fd6 100%);
        --maxw: 1320px;
        --font:
          'Switzer', ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial,
          sans-serif;
        --mono: ui-monospace, 'SF Mono', SFMono-Regular, Menlo, Consolas, monospace;
      }
      * {
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
        min-height: 100vh;
        overflow-x: hidden;
        font-family: var(--font);
        font-weight: 400;
        background:
          radial-gradient(50rem 30rem at 50% -8%, rgba(99, 102, 241, 0.07), transparent 60%),
          var(--bg);
        color: var(--fg);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        line-height: 1.55;
      }
      a {
        color: var(--accent);
        text-decoration: none;
      }
      h1, h2, h3, h4, h5, h6 {
        font-weight: 500;
        line-height: 1.14;
        letter-spacing: -0.012em;
        color: var(--fg);
      }
      ::selection {
        background: rgba(99, 102, 241, 0.18);
      }
      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      /* ----- App shell ----- */
      .app-shell {
        width: 100%;
      }
      .gutter {
        width: 100%;
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 0 clamp(1.25rem, 4vw, 3rem);
      }
      .app-nav {
        position: sticky;
        top: 0;
        z-index: 50;
        width: 100%;
        margin-bottom: 0;
        background: rgba(246, 247, 249, 0.82);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
      }
      .app-nav__inner {
        width: 100%;
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 0.8rem clamp(1.25rem, 4vw, 3rem);
        display: flex;
        align-items: center;
        gap: 1.25rem;
      }
      .app-brand {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--fg);
        font-weight: 500;
        letter-spacing: -0.01em;
      }
      .app-brand__mark {
        display: grid;
        place-items: center;
        width: 30px;
        height: 30px;
        border-radius: 9px;
        background: var(--surface);
        border: 1px solid var(--border);
        box-shadow: var(--shadow-sm);
      }
      .app-brand__text {
        font-size: 1.05rem;
      }
      .app-nav__links {
        display: flex;
        align-items: center;
        gap: 0.15rem;
        flex: 1;
        justify-content: center;
      }
      .app-nav__link {
        padding: 0.45rem 0.85rem;
        border-radius: 999px;
        color: var(--muted);
        font-size: 0.9rem;
        font-weight: 500;
        transition: color 0.15s ease, background 0.15s ease;
      }
      .app-nav__link:hover {
        color: var(--fg);
        background: var(--surface-2);
      }
      .app-nav__link--active {
        color: var(--accent);
        background: rgba(79, 70, 229, 0.08);
      }
      .app-nav__actions {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-left: auto;
      }
      .app-main {
        min-height: 50vh;
        width: 100%;
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 2.5rem clamp(1.25rem, 4vw, 3rem) 4rem;
      }
      /* The landing manages its own section widths (some are full-bleed). */
      .app-main--home {
        max-width: none;
        padding: 0;
      }
      .app-footer {
        width: 100%;
        margin-top: 3rem;
        border-top: 1px solid var(--border);
        background: var(--surface);
      }
      .app-footer__inner {
        width: 100%;
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 1.5rem clamp(1.25rem, 4vw, 3rem) 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        color: var(--muted);
        font-size: 0.82rem;
        text-align: center;
      }
      .app-footer__dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--ok);
        box-shadow: 0 0 0 3px rgba(5, 150, 105, 0.15);
      }
      @media (max-width: 760px) {
        .app-nav__inner {
          flex-wrap: wrap;
          gap: 0.75rem;
        }
        .app-nav__links {
          order: 3;
          width: 100%;
          justify-content: flex-start;
          overflow-x: auto;
        }
      }

      /* ----- Reusable primitives ----- */
      .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
      }
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.65rem 1.3rem;
        border-radius: 10px;
        border: 1px solid transparent;
        font-family: inherit;
        font-size: 0.92rem;
        font-weight: 500;
        cursor: pointer;
        transition: transform 0.12s ease, filter 0.15s ease, background 0.15s ease, opacity 0.15s ease;
      }
      .btn:active {
        transform: translateY(1px);
      }
      .btn--primary {
        background: var(--purple);
        color: #fff;
        border: 1px solid var(--purple-edge);
        text-shadow: 0 1px 1px rgba(40, 28, 110, 0.45);
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.45),
          inset 0 2px 3px rgba(255, 255, 255, 0.18),
          inset 0 -6px 12px rgba(40, 28, 110, 0.5),
          inset 0 -1px 0 rgba(40, 28, 110, 0.6);
      }
      .btn--primary:hover {
        background: var(--purple-hi);
      }
      .btn--primary:active {
        transform: translateY(1px);
        box-shadow:
          inset 0 2px 6px rgba(40, 28, 110, 0.55),
          inset 0 1px 0 rgba(255, 255, 255, 0.2);
      }
      .btn--ghost {
        background: var(--surface);
        border-color: var(--border-strong);
        color: var(--fg);
      }
      .btn--ghost:hover {
        background: var(--surface-2);
      }
      .btn:disabled,
      .btn[aria-disabled='true'] {
        opacity: 0.45;
        cursor: not-allowed;
        transform: none;
        filter: none;
      }
      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        font-size: 0.74rem;
        font-weight: 500;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--accent);
      }
      .page-head {
        margin: 0 auto 2rem;
        text-align: center;
        max-width: 64ch;
      }
      .page-head h1 {
        margin: 0.5rem 0 0.5rem;
        font-size: clamp(1.9rem, 3.4vw, 2.6rem);
      }
      .page-head p {
        margin: 0 auto;
        color: var(--muted);
        max-width: 60ch;
      }

      /* ----- Network badge ----- */
      .network-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.32rem 0.7rem;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 500;
        border: 1px solid transparent;
        white-space: nowrap;
      }
      .network-badge::before {
        content: '';
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: currentColor;
      }
      .network-badge--ok {
        background: rgba(5, 150, 105, 0.1);
        color: var(--ok);
        border-color: rgba(5, 150, 105, 0.25);
      }
      .network-badge--warn {
        background: rgba(217, 119, 6, 0.1);
        color: var(--warn);
        border-color: rgba(217, 119, 6, 0.28);
      }
      .network-badge--idle {
        background: var(--surface-2);
        color: var(--muted);
        border-color: var(--border);
      }
    </style>
    <style is:global>
      /* ----- Landing / hero (centered) ----- */
      .hero {
        max-width: 60rem;
        margin: 1rem auto 0;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
      }
      .hero__title {
        margin: 1rem auto 0.9rem;
        font-size: clamp(2.4rem, 5.5vw, 3.8rem);
        font-weight: 500;
        letter-spacing: -0.02em;
        max-width: 18ch;
      }
      .hero__title .grad {
        background: var(--gradient);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: 500;
      }
      .hero__lede {
        margin: 0 auto 1.4rem;
        font-size: 1.1rem;
        color: var(--muted);
        max-width: 56ch;
      }
      .hero__cta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        justify-content: center;
      }
      .hero__pills {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        justify-content: center;
        margin: 1.5rem auto 0;
      }
      .pill {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.35rem 0.8rem;
        border-radius: 999px;
        background: var(--surface);
        border: 1px solid var(--border);
        color: var(--fg-soft);
        font-size: 0.82rem;
        font-weight: 500;
        box-shadow: var(--shadow-sm);
      }
      .pill__key {
        color: var(--accent);
        font-weight: 500;
      }

      /* product preview graphic — centered, below the hero text */
      .hero__graphic {
        width: min(100%, 56rem);
        margin: 2.75rem auto 0;
        padding: 1.25rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 20px;
        box-shadow: var(--shadow);
        text-align: left;
      }
      .preview-bar {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding-bottom: 0.9rem;
        margin-bottom: 1rem;
        border-bottom: 1px solid var(--border);
      }
      .preview-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--border-strong);
      }
      .preview-bar__label {
        margin-left: 0.5rem;
        font-size: 0.78rem;
        color: var(--muted);
      }
      .preview-grid {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 1.5rem;
        align-items: center;
      }
      @media (max-width: 560px) {
        .preview-grid {
          grid-template-columns: 1fr;
        }
      }
      .preview-gauge {
        display: grid;
        place-items: center;
        width: 130px;
        height: 130px;
        border-radius: 50%;
        background: conic-gradient(#6366f1 0 26%, var(--surface-2) 26% 100%);
        position: relative;
      }
      .preview-gauge::after {
        content: '';
        position: absolute;
        inset: 12px;
        border-radius: 50%;
        background: var(--surface);
      }
      .preview-gauge__inner {
        position: relative;
        z-index: 1;
        text-align: center;
      }
      .preview-gauge__val {
        font-size: 2.1rem;
        font-weight: 500;
      }
      .preview-gauge__lbl {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
      }
      .preview-spark {
        width: 100%;
        height: 90px;
      }
      .preview-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-top: 0.9rem;
      }
      .preview-tag {
        font-size: 0.72rem;
        font-weight: 500;
        padding: 0.2rem 0.55rem;
        border-radius: 999px;
        background: var(--surface-2);
        color: var(--fg-soft);
        border: 1px solid var(--border);
      }
      .preview-tag--ok {
        background: rgba(5, 150, 105, 0.1);
        color: var(--ok);
        border-color: rgba(5, 150, 105, 0.22);
      }

      /* section heads + feature grid (centered) */
      .section-head {
        margin: 3.5rem auto 1.5rem;
        text-align: center;
      }
      .section-head h2 {
        margin: 0.4rem 0 0;
        font-size: clamp(1.5rem, 3vw, 2rem);
      }
      .feature-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
      }
      @media (max-width: 820px) {
        .feature-grid {
          grid-template-columns: 1fr;
        }
      }
      .feature {
        padding: 1.5rem;
        text-align: center;
      }
      .feature__icon {
        display: grid;
        place-items: center;
        width: 44px;
        height: 44px;
        margin: 0 auto 0.9rem;
        border-radius: 12px;
        background: rgba(99, 102, 241, 0.08);
        border: 1px solid var(--border);
        font-size: 1.2rem;
      }
      .feature h3 {
        margin: 0 0 0.4rem;
        font-size: 1.1rem;
        font-weight: 500;
      }
      .feature p {
        margin: 0;
        color: var(--muted);
        font-size: 0.9rem;
      }

      /* ----- Wallet panel (landing) — centered ----- */
      .wallet-panel {
        max-width: 32rem;
        margin: 1.25rem auto 0;
        padding: 1.5rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        text-align: center;
      }
      .wallet-panel__row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        justify-content: center;
      }
      .wallet-panel__state {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 1rem;
        padding: 0.55rem 0.8rem;
        border-radius: var(--radius-sm);
        background: var(--surface-2);
        border: 1px solid var(--border);
        font-size: 0.85rem;
      }
      .wallet-panel__address {
        font-family: var(--mono);
        font-size: 0.82rem;
        color: var(--fg-soft);
      }
      .wallet-panel__hint {
        color: var(--muted);
        margin: 1rem 0 0;
        font-size: 0.9rem;
      }
      .wallet-panel__sign {
        margin-top: 1.1rem;
      }
      .wallet-panel__feedback {
        margin: 0.85rem auto 0;
        max-width: 26rem;
        padding: 0.7rem 0.85rem;
        border-radius: var(--radius-sm);
        font-size: 0.85rem;
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
        text-align: left;
      }
      .wallet-panel__feedback--ok {
        background: rgba(5, 150, 105, 0.08);
        border: 1px solid rgba(5, 150, 105, 0.25);
        color: var(--ok);
      }
      .wallet-panel__feedback--err {
        background: rgba(220, 38, 38, 0.07);
        border: 1px solid rgba(220, 38, 38, 0.25);
        color: var(--danger);
      }
      .wallet-panel__sig {
        font-family: var(--mono);
        font-size: 0.74rem;
        color: var(--fg-soft);
        word-break: break-all;
      }
      .spinner {
        width: 14px;
        height: 14px;
        border-radius: 50%;
        border: 2px solid rgba(255, 255, 255, 0.4);
        border-top-color: #fff;
        animation: spin 0.7s linear infinite;
        flex: 0 0 auto;
      }
      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }
      .wrong-network-banner {
        margin: 0.85rem auto 0;
        max-width: 26rem;
        padding: 0.7rem 0.85rem;
        border-radius: var(--radius-sm);
        background: rgba(217, 119, 6, 0.08);
        border: 1px solid rgba(217, 119, 6, 0.3);
        color: var(--warn);
        font-size: 0.85rem;
        text-align: left;
      }

      /* dApp Kit connect button — sized to match the .network-badge pill height */
      .wallet-menu {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
      }
      .wallet-menu button {
        font-family: inherit !important;
        font-weight: 500 !important;
        font-size: 0.85rem !important;
        line-height: 1.2 !important;
        padding: 0.5rem 1rem !important;
        min-height: 0 !important;
        height: auto !important;
        border-radius: 10px !important;
        background: var(--purple) !important;
        color: #fff !important;
        border: 1px solid var(--purple-edge) !important;
        text-shadow: 0 1px 1px rgba(40, 28, 110, 0.45) !important;
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.45),
          inset 0 2px 3px rgba(255, 255, 255, 0.18),
          inset 0 -5px 10px rgba(40, 28, 110, 0.5),
          inset 0 -1px 0 rgba(40, 28, 110, 0.6) !important;
      }
      .wallet-menu button:hover {
        background: var(--purple-hi) !important;
      }
      /* Force the connected account label (and any inner span) to white so the
         address reads on the purple button, not dApp Kit's default dark body. */
      .wallet-menu button,
      .wallet-menu button * {
        color: #fff !important;
      }
      /* dApp Kit theme: white primary-button text + a sharp dropdown radius. */
      [data-dapp-kit] {
        --dapp-kit-colors-primaryButton: #ffffff;
        --dapp-kit-radii-large: 12px;
      }
      /* 3D effect on the account dropdown (Radix menu), no layout/margin change. */
      [data-dapp-kit][role='menu'] {
        border: 1px solid var(--purple-edge) !important;
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.7),
          0 12px 30px rgba(40, 28, 110, 0.22),
          0 3px 8px rgba(15, 23, 42, 0.14) !important;
      }

      /* ----- Wallet connect gate (protected pages) ----- */
      .connect-gate {
        max-width: 30rem;
        margin: 2rem auto 0;
        padding: 2.5rem 1.75rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.6rem;
      }
      .connect-gate__icon {
        font-size: 1.75rem;
        width: 56px;
        height: 56px;
        display: grid;
        place-items: center;
        border-radius: 14px;
        background: rgba(99, 102, 241, 0.08);
        border: 1px solid var(--border);
      }
      .connect-gate__title {
        margin: 0.4rem 0 0;
        font-size: 1.3rem;
      }
      .connect-gate__lede {
        margin: 0;
        color: var(--muted);
        font-size: 0.92rem;
        max-width: 40ch;
      }
      .connect-gate__action {
        margin-top: 0.8rem;
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
      }
      .connect-gate__action button {
        font-family: inherit !important;
        font-weight: 500 !important;
        border-radius: 10px !important;
      }

      /* Landing connect row, under the hero CTAs */
      .hero__connect {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        margin: 1.25rem auto 0;
      }
      .hero__connect button {
        font-family: inherit !important;
        font-weight: 500 !important;
        border-radius: 10px !important;
      }

      /* ----- Policy wizard ----- */
      .policy-wizard {
        max-width: 40rem;
        margin: 0 auto;
      }
      .wizard-stepper {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        list-style: none;
        margin: 0 0 1.5rem;
        padding: 0;
        justify-content: center;
      }
      .wizard-stepper__item {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.35rem 0.7rem;
        border-radius: 999px;
        font-size: 0.8rem;
        font-weight: 500;
        background: var(--surface-2);
        color: var(--muted);
        border: 1px solid var(--border);
      }
      .wizard-stepper__item--active {
        background: rgba(79, 70, 229, 0.08);
        color: var(--accent);
        border-color: rgba(79, 70, 229, 0.3);
      }
      .wizard-stepper__item--done {
        background: rgba(5, 150, 105, 0.1);
        color: var(--ok);
        border-color: rgba(5, 150, 105, 0.25);
      }
      .wizard-stepper__index {
        font-weight: 500;
      }
      .wizard-step {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.5rem;
        box-shadow: var(--shadow);
      }
      .wizard-step__hint {
        color: var(--muted);
        font-size: 0.9rem;
      }
      .wizard-options {
        display: flex;
        flex-wrap: wrap;
